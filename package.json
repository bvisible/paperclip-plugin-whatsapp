{
  "name": "@bvisible/paperclip-plugin-whatsapp",
  "version": "0.1.0",
  "description": "WhatsApp plugin for Paperclip — webhook receiver + whatsapp_send tool. Talks to a custom Baileys-based router on neoservice (NORA Phase 2, Chemin 2).",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Bvisible",
  "homepage": "https://github.com/bvisible/paperclip-plugin-whatsapp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bvisible/paperclip-plugin-whatsapp.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.428.0",
    "@paperclipai/shared": "^2026.428.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "whatsapp",
    "baileys",
    "nora",
    "neoffice"
  ]
}
